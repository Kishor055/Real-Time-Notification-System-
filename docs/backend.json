
{
  "entities": {
    "Notification": {
      "title": "Notification",
      "description": "An enterprise-grade real-time notification event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "topic": { "type": "string", "enum": ["trading", "alerts", "monitoring", "security", "general"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "aiCategory": { "type": "string" },
        "aiPriority": { "type": "string" },
        "aiSummary": { "type": "string" }
      },
      "required": ["userId", "topic", "title", "message", "severity", "status", "createdAt"]
    },
    "Topic": {
      "title": "Topic",
      "description": "A communication channel for notification broadcasting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "active": { "type": "boolean" },
        "subscribersCount": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["name", "active", "subscribersCount"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Enterprise user profile with presence tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "away"] },
        "lastActive": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "operator", "viewer"] }
      },
      "required": ["email", "status", "lastActive"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/notifications/{notificationId}": {
      "schema": "#/backend/entities/Notification",
      "description": "Real-time feed of system-wide notifications."
    },
    "/topics/{topicId}": {
      "schema": "#/backend/entities/Topic",
      "description": "Managed subscription channels for the orchestration engine."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profiles and global presence data."
    }
  }
}
